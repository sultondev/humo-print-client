# Copy this file to .env and fill in values for your environment.
# In CI/CD pipelines, inject these as environment variables directly —
# no .env file needed on the server.

# ── development  → http://localhost:3001
# ── staging      → https://api-staging.humoprint.uz   (set by CI on staging deploy)
# ── production   → https://api.humoprint.uz           (set by CI on prod deploy)
NUXT_PUBLIC_API_URL=http://localhost:3001
